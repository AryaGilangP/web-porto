{
  "version": 2,
  "framework": null,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/static/core/(.*)",
      "destination": "/static_deployed/$1"
    },
    {
      "source": "/static/(.*)",
      "destination": "/static_deployed/$1"
    },
    {
      "source": "/(.*)",
      "destination": "config/asgi.py"
    }
  ]
}